# 1. Tự động chuẩn hóa ký tự xuống dòng cho tất cả các file text
* text=auto eol=lf
# 2. Ép buộc các file code C/C++ và Script luôn dùng LF (bất kể code trên OS nào)
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.sh text eol=lf
Makefile text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
# 3. Đánh dấu các file dữ liệu test/benchmark lớn để dùng Git LFS
*.pcap filter=lfs diff=lfs merge=lfs -text
*.pcapng filter=lfs diff=lfs merge=lfs -text
*.db filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.so filter=lfs diff=lfs merge=lfs -text
*.so* filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
